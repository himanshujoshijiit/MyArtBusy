# Database — NEVER use defaults in production
POSTGRES_PASSWORD=change-me-to-a-long-random-password

# JWT - change in production (min 256 bits)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-256-bits-long

# Production security — set true on VPS
REQUIRE_SECURE_JWT=false

# Launch mode — set false for single-artist launch (no commission, no booking cap)
MARKETPLACE_MODE=false
COMMISSION_RATE=0
FREE_TIER_BOOKINGS=9999
DEFAULT_MUA_TIER=PRO

# Razorpay — leave BOTH empty for mock/demo checkout; use real test/live keys for payments
# Get keys: https://dashboard.razorpay.com → Settings → API Keys → Generate Key
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_from_razorpay_dashboard

# Cloudinary (recommended for portfolio images in production)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=

# WhatsApp Business API (Meta Cloud API) — also used for OTP delivery
WHATSAPP_API_KEY=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=makeupseven_webhook_verify

# Email (optional — mock logs when empty)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@makeupseven.com

# Production HTTPS (Caddy profile)
DOMAIN=yourdomain.com
ACME_EMAIL=you@yourdomain.com

# Frontend URLs (for CORS, SEO, notifications)
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_SEARCH_URL=http://localhost:8000

# Uploads
UPLOAD_DIR=uploads

# Local dev: docker compose up
# Production: docker compose -f docker-compose.yml -f docker-compose.prod.yml --profile production up -d
# Backup cron: scripts/backup-db.sh (set BACKUP_S3_BUCKET for off-server copies)
# Firewall: sudo scripts/setup-firewall.sh
