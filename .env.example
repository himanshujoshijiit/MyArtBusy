# JWT - change in production (min 256 bits)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-256-bits-long

# Razorpay (https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_from_razorpay_dashboard

# Cloudinary (recommended for portfolio images in production)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=

# Production security — set true to refuse weak JWT secrets at startup
REQUIRE_SECURE_JWT=false

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_API_KEY=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=makeupseven_webhook_verify

# Email (optional — mock logs when empty)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@makeupseven.com

# Frontend URLs (for CORS, SEO, notifications)
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_SEARCH_URL=http://localhost:8000

# Uploads
UPLOAD_DIR=uploads

# Optional: unified gateway on port 80
# docker compose --profile gateway up
